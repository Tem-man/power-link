{
  "name": "power-link",
  "version": "2.0.5",
  "description": "A pure TypeScript visual node connector for creating draggable connections between nodes. Framework-agnostic and easy to use",
  "author": {
    "name": "Lin Ji Man",
    "email": "Temman_lin@qq.com"
  },
  "keywords": [
    "connector",
    "node-link",
    "visual-connector",
    "drag-line",
    "bezier-curve",
    "high-customization",
    "flow-chart"
  ],
  "license": "MIT",
  "homepage": "https://tem-man.github.io/power-link",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tem-man/power-link.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "devDependencies": {
    "@connector/tsconfig": "workspace:*",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  }
}
